NODE_ENV=development
APP_URL=http://localhost:3000
WEB_PORT=3000
REALTIME_PORT=3001
DATABASE_URL=postgresql://twitter:twitter@localhost:5432/twitter
REDIS_URL=redis://localhost:6379
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
# Keep enabled outside isolated demo environments. Codespaces may opt out for email-free testing.
AUTH_REQUIRE_EMAIL_VERIFICATION=true
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=twitter-media
S3_PRIVATE_BUCKET=twitter-private
S3_ACCESS_KEY=twitter
S3_SECRET_KEY=twitter-dev-secret
S3_PUBLIC_URL=http://localhost:9000/twitter-media
# Codespaces overrides these with smaller public-demo limits.
MEDIA_MAX_IMAGE_BYTES=15728640
MEDIA_MAX_VIDEO_BYTES=536870912
MEDIA_PRESIGN_LIMIT=120
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=Twitter <no-reply@twitter.local>
BOOTSTRAP_ADMIN_EMAIL=
GIPHY_API_KEY=
REALTIME_SHARED_SECRET=replace-with-a-second-32-character-random-secret
INTERNAL_API_URL=http://web:3000
