{
  "name": "twitter-2020-clone",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "pnpm --filter @twitter2020/web test:e2e",
    "test:visual": "pnpm --filter @twitter2020/web test:visual",
    "maintenance:on": "node --env-file-if-exists=.env scripts/maintenance-mode.mjs on",
    "maintenance:off": "node --env-file-if-exists=.env scripts/maintenance-mode.mjs off",
    "maintenance:status": "node --env-file-if-exists=.env scripts/maintenance-mode.mjs status",
    "db:generate": "pnpm --filter @twitter2020/db db:generate",
    "db:migrate": "pnpm --filter @twitter2020/db db:migrate",
    "db:studio": "pnpm --filter @twitter2020/db db:studio",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "^6.0.3"
  }
}
